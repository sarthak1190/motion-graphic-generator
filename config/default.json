{
  "brand": {
    "handle": "@java_learning_hub_",
    "challengeBadge": "Developer Learning Sprint",
    "footerPrefix": "Follow for more",
    "cta": [
      "Save This Post",
      "Follow For More",
      "Share With A Friend"
    ]
  },
  "canvas": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "durationSeconds": 3,
    "format": "9:16"
  },
  "output": {
    "dir": "output",
    "minClips": 1,
    "maxClips": 20,
    "minTotalSeconds": 15,
    "preferredMinTotalSeconds": 45,
    "preferredMaxTotalSeconds": 75,
    "maxTotalSeconds": 180,
    "minSceneSeconds": 2.0,
    "maxSceneSeconds": 5.0,
    "finalHoldSeconds": 0.5,
    "minFinalTextOpacity": 0.85,
    "maxGifClips": 60,
    "gifFps": 12,
    "gifWidth": 720,
    "maxVisibleBlocksPerScene": 5,
    "showFooterChips": true,
    "keepFrames": false,
    "keepHtml": true
  },
  "theme": {
    "background": "#090D16",
    "primary": "#F89820",
    "secondary": "#38BDF8",
    "card": "#131B2E",
    "cardStrong": "#1E293B",
    "text": "#F8FAFC",
    "ink": "#F8FAFC",
    "muted": "#94A3B8",
    "success": "#34D399",
    "danger": "#F87171"
  },
  "render": {
    "concurrency": 1,
    "captureStartSeconds": 0.25,
    "mountDelayMs": 500,
    "puppeteerLaunchArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--font-render-hinting=none"
    ]
  },
  "features": {
    "voiceover": {
      "enabled": false,
      "voice": "Daniel",
      "delayMs": 800
    },
    "introVideo": {
      "enabled": true,
      "path": "video/Cat-Toss.mp4"
    }
  }
}